{
  "name": "lechworld",
  "version": "1.0.0",
  "description": "Family Loyalty Program Tracker - Airline Miles & Points Management",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch server/index.ts --port 3000",
    "build": "npm run build:client",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "tsc",
    "start": "node dist/server/index.js --port 3000",
    "vercel-build": "./scripts/prepare-vercel.sh && npm run build:client",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:update-values": "tsx scripts/update-point-values.ts",
    "db:seed-users": "tsx scripts/seed-users.ts",
    "db:import-real": "tsx scripts/import-real-data.ts",
    "test": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.17.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.29.3",
    "drizzle-zod": "^0.5.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.316.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wouter": "^3.0.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.56.0",
    "postcss": "^8.4.33",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
