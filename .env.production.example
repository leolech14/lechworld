# Production Environment Configuration - LechWorld
# NEVER commit actual secrets to version control
# Use secure secret management services in production

# =============================================================================
# CRITICAL SECURITY CONFIGURATION
# =============================================================================

# JWT Authentication (Generate with: openssl rand -base64 64)
JWT_SECRET=PLACEHOLDER_JWT_SECRET_REPLACE_WITH_SECURE_RANDOM_64_BYTE_STRING
JWT_REFRESH_SECRET=PLACEHOLDER_JWT_REFRESH_SECRET_REPLACE_WITH_SECURE_RANDOM_64_BYTE_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=lechworld-production
JWT_AUDIENCE=lechworld-users

# Encryption Keys (Generate with: openssl rand -hex 32)
ENCRYPTION_KEY=PLACEHOLDER_ENCRYPTION_KEY_REPLACE_WITH_SECURE_HEX_32_BYTES
SESSION_SECRET=PLACEHOLDER_SESSION_SECRET_REPLACE_WITH_SECURE_RANDOM_STRING
CSRF_SECRET=PLACEHOLDER_CSRF_SECRET_REPLACE_WITH_SECURE_RANDOM_STRING

# Password Security
BCRYPT_ROUNDS=14
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=4

# API Security Keys
API_KEY_SECRET=PLACEHOLDER_API_KEY_SECRET_REPLACE_WITH_SECURE_RANDOM_STRING
WEBHOOK_SECRET=PLACEHOLDER_WEBHOOK_SECRET_REPLACE_WITH_SECURE_RANDOM_STRING

# =============================================================================
# DATABASE CONFIGURATION (PRODUCTION)
# =============================================================================

# Primary Database (Use managed PostgreSQL service)
DATABASE_URL=PLACEHOLDER_REPLACE_WITH_PRODUCTION_POSTGRES_CONNECTION_STRING
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Database Pool Settings (Production optimized)
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50
DATABASE_IDLE_TIMEOUT=10000
DATABASE_CONNECTION_TIMEOUT=3000
DATABASE_STATEMENT_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=60000

# Read Replica Configuration (Optional)
DATABASE_READ_REPLICA_URL=PLACEHOLDER_REPLACE_WITH_READ_REPLICA_CONNECTION_STRING

# Redis Configuration (Use managed Redis service)
REDIS_URL=PLACEHOLDER_REPLACE_WITH_PRODUCTION_REDIS_CONNECTION_STRING
REDIS_PASSWORD=PLACEHOLDER_REPLACE_WITH_REDIS_PASSWORD
REDIS_TLS=true
REDIS_KEY_PREFIX=lechworld:prod:
REDIS_POOL_MIN=5
REDIS_POOL_MAX=20

# =============================================================================
# EXTERNAL SERVICE CREDENTIALS
# =============================================================================

# AI Services (Store in secure vault)
ANTHROPIC_API_KEY=PLACEHOLDER_REPLACE_WITH_ANTHROPIC_API_KEY
OPENAI_API_KEY=PLACEHOLDER_REPLACE_WITH_OPENAI_API_KEY

# GitHub Integration
GITHUB_TOKEN=PLACEHOLDER_REPLACE_WITH_GITHUB_PERSONAL_ACCESS_TOKEN
GITHUB_CLIENT_ID=PLACEHOLDER_REPLACE_WITH_GITHUB_OAUTH_CLIENT_ID
GITHUB_CLIENT_SECRET=PLACEHOLDER_REPLACE_WITH_GITHUB_OAUTH_CLIENT_SECRET

# Email Service (Use managed email service)
SMTP_HOST=PLACEHOLDER_REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=PLACEHOLDER_REPLACE_WITH_SMTP_USERNAME
SMTP_PASS=PLACEHOLDER_REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM=noreply@lechworld.com

# Object Storage (S3/Compatible)
S3_ENDPOINT=PLACEHOLDER_REPLACE_WITH_S3_ENDPOINT
S3_ACCESS_KEY=PLACEHOLDER_REPLACE_WITH_S3_ACCESS_KEY
S3_SECRET_KEY=PLACEHOLDER_REPLACE_WITH_S3_SECRET_KEY
S3_BUCKET=lechworld-production-assets
S3_REGION=us-east-1
S3_SSL=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Application Monitoring
SENTRY_DSN=PLACEHOLDER_REPLACE_WITH_SENTRY_DSN
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# Metrics & Analytics
PROMETHEUS_URL=PLACEHOLDER_REPLACE_WITH_PROMETHEUS_ENDPOINT
GRAFANA_URL=PLACEHOLDER_REPLACE_WITH_GRAFANA_URL
DATADOG_API_KEY=PLACEHOLDER_REPLACE_WITH_DATADOG_API_KEY
NEW_RELIC_LICENSE_KEY=PLACEHOLDER_REPLACE_WITH_NEW_RELIC_KEY

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=PLACEHOLDER_REPLACE_WITH_OTEL_ENDPOINT
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer PLACEHOLDER_OTEL_TOKEN
OTEL_SERVICE_NAME=lechworld-production
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=production

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Timezone & Locale
TZ=UTC
LANG=en_US.UTF-8

# Performance Optimization
NODE_OPTIONS=--max-old-space-size=2048 --optimize-for-size
UV_THREADPOOL_SIZE=16
MAX_HTTP_HEADER_SIZE=8192

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration (Production domains only)
CORS_ORIGIN=https://lechworld.com,https://www.lechworld.com,https://api.lechworld.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false
CSP_REPORT_URI=https://api.lechworld.com/api/csp-report
CSP_NONCE_SECRET=PLACEHOLDER_REPLACE_WITH_CSP_NONCE_SECRET

# Session Configuration
SESSION_NAME=lechworld.sid
SESSION_DURATION=900000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Rate Limiting (Production limits)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_BURST_SIZE=50
RATE_LIMIT_SKIP_FAILED=true

# Security Headers
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# =============================================================================
# FEATURE FLAGS (PRODUCTION)
# =============================================================================

# Core Features
ENABLE_GUARDIAN_ENFORCER=true
ENABLE_AUDIT_TRAIL=true
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_TRACKING=true

# Security Features
ENABLE_CORS=true
ENABLE_HELMET=true
ENABLE_COMPRESSION=true
ENABLE_REQUEST_VALIDATION=true
ENABLE_CSRF_PROTECTION=true
ENABLE_XSS_PROTECTION=true

# Performance Features
ENABLE_CACHING=true
ENABLE_GZIP=true
ENABLE_HTTP2=true
ENABLE_METRICS_COLLECTION=true

# Debug Features (Disabled in production)
ENABLE_HOT_RELOAD=false
ENABLE_SOURCE_MAPS=false
ENABLE_DEBUG_LOGS=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels
LOG_LEVEL=warn
AUDIT_LOG_LEVEL=info
SECURITY_LOG_LEVEL=info
PERFORMANCE_LOG_LEVEL=error

# Log Destinations
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/var/log/lechworld/app.log
LOG_FILE_MAX_SIZE=100mb
LOG_FILE_MAX_FILES=10

# Structured Logging
LOG_FORMAT=json
LOG_TIMESTAMP=true
LOG_CORRELATION_ID=true

# =============================================================================
# HEALTH & MONITORING
# =============================================================================

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8081
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Readiness Checks
READINESS_CHECK_ENABLED=true
READINESS_CHECK_PATH=/ready
READINESS_CHECK_DB=true
READINESS_CHECK_REDIS=true

# Metrics Collection
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_COLLECTION_INTERVAL=15000

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION_KEY=PLACEHOLDER_REPLACE_WITH_BACKUP_ENCRYPTION_KEY
BACKUP_S3_BUCKET=lechworld-production-backups

# Disaster Recovery
DR_ENABLED=true
DR_RTO_MINUTES=30
DR_RPO_MINUTES=15

# =============================================================================
# COMPLIANCE & GOVERNANCE
# =============================================================================

# Compliance Configuration
COMPLIANCE_MODE=soc2
GDPR_ENABLED=true
CCPA_ENABLED=true
HIPAA_ENABLED=false

# Data Governance
DATA_RETENTION_ENABLED=true
DATA_RETENTION_DAYS=2555
DATA_ANONYMIZATION_ENABLED=true
DATA_EXPORT_ENABLED=true

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=2555
AUDIT_ENCRYPTION_ENABLED=true
AUDIT_EXPORT_FORMAT=json

# =============================================================================
# CONTAINER & ORCHESTRATION
# =============================================================================

# Container Configuration
CONTAINER_REGISTRY=PLACEHOLDER_REPLACE_WITH_CONTAINER_REGISTRY
CONTAINER_TAG=latest
CONTAINER_HEALTHCHECK_INTERVAL=30s

# Kubernetes Configuration
K8S_NAMESPACE=lechworld-production
K8S_CONFIG_PATH=/etc/kubernetes/config
K8S_SERVICE_ACCOUNT=lechworld-service

# Load Balancer Configuration
LB_HEALTH_CHECK_PATH=/health
LB_HEALTH_CHECK_INTERVAL=30
LB_UNHEALTHY_THRESHOLD=3
LB_HEALTHY_THRESHOLD=2

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Payment Processing (if applicable)
STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=PLACEHOLDER_REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# Analytics
GOOGLE_ANALYTICS_ID=PLACEHOLDER_REPLACE_WITH_GA_ID
MIXPANEL_TOKEN=PLACEHOLDER_REPLACE_WITH_MIXPANEL_TOKEN

# CDN Configuration
CDN_ENABLED=true
CDN_BASE_URL=https://cdn.lechworld.com
CDN_CACHE_TTL=31536000

# =============================================================================
# CUSTOM APPLICATION SETTINGS
# =============================================================================

# Application Specific
APP_NAME=LechWorld
APP_VERSION=1.0.0
APP_DESCRIPTION=LechWorld Production Application
APP_DOMAIN=lechworld.com

# Feature Toggles
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BETA_FEATURES=false

# Business Logic
MAX_FILE_UPLOAD_SIZE=10485760
MAX_REQUEST_BODY_SIZE=1048576
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# Integration Timeouts
EXTERNAL_API_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=60000
CACHE_TTL=3600
SESSION_TTL=900

# =============================================================================
# INFRASTRUCTURE SECRETS
# =============================================================================

# SSL/TLS Certificates (Use certificate management service)
SSL_CERT_PATH=/etc/ssl/certs/lechworld.crt
SSL_KEY_PATH=/etc/ssl/private/lechworld.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# Service Mesh (if applicable)
SERVICE_MESH_ENABLED=false
ISTIO_ENABLED=false
CONSUL_CONNECT_ENABLED=false

# Secret Management
VAULT_ENABLED=false
VAULT_URL=PLACEHOLDER_REPLACE_WITH_VAULT_URL
VAULT_TOKEN=PLACEHOLDER_REPLACE_WITH_VAULT_TOKEN
VAULT_NAMESPACE=lechworld

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Deployment Settings
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_STRATEGY=blue-green
DEPLOYMENT_TIMEOUT=600
ROLLBACK_ENABLED=true

# Auto-scaling
AUTO_SCALING_ENABLED=true
MIN_REPLICAS=3
MAX_REPLICAS=50
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=50
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30000

# =============================================================================
# WARNING: SECURITY NOTICE
# =============================================================================
# 
# 🚨 CRITICAL SECURITY REMINDERS:
# 
# 1. Replace ALL PLACEHOLDER values with actual secure secrets
# 2. Use a secure secret management service (AWS Secrets Manager, Azure Key Vault, etc.)
# 3. Never commit actual secrets to version control
# 4. Rotate secrets regularly (every 90 days minimum)
# 5. Use least-privilege access principles
# 6. Monitor secret access and usage
# 7. Enable audit logging for all secret operations
# 8. Use encrypted storage for all sensitive data
# 9. Implement proper secret injection in your deployment pipeline
# 10. Test secret rotation procedures regularly
#
# =============================================================================