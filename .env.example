# Ultimate Monorepo Environment Configuration
# Copy to .env and customize for your environment

# =============================================================================
# API KEYS & AUTHENTICATION
# =============================================================================

# AI Agent API Keys (Required for agent functionality)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# Authentication & Security
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
BCRYPT_ROUNDS=12
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary Database (PostgreSQL)
DATABASE_URL=postgresql://orchestrator:orchestrator123@localhost:5432/orchestrator
TEST_DATABASE_URL=postgresql://orchestrator:orchestrator123@localhost:5432/orchestrator_test

# Database Pool Settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=5000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=monorepo:

# =============================================================================
# MESSAGE QUEUE & COMMUNICATION
# =============================================================================

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RABBITMQ_EXCHANGE=monorepo_events
RABBITMQ_QUEUE_PREFIX=monorepo

# Agent Coordination
AGENT_COORDINATION_URL=http://localhost:8765
AGENT_LOG_BUS_DIR=/tmp/dream-team-logs
AGENT_MAX_PARALLEL=8
AGENT_DEFAULT_TIMEOUT=300000

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Application Monitoring
SENTRY_DSN=
LOG_LEVEL=info
DEBUG=app:*

# Metrics & Tracing
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
JAEGER_URL=http://localhost:16686
LOKI_URL=http://localhost:3100

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=monorepo-app
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=development

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_PATH=/health

# =============================================================================
# FEATURE FLAGS & CONFIGURATION
# =============================================================================

# Core Features
ENABLE_GUARDIAN_ENFORCER=true
ENABLE_AUDIT_TRAIL=true
ENABLE_RATE_LIMITING=true
ENABLE_AGENT_COORDINATION=true
ENABLE_TRACING=true
ENABLE_METRICS=true

# Security Features
ENABLE_CORS=true
ENABLE_HELMET=true
ENABLE_COMPRESSION=true
ENABLE_REQUEST_VALIDATION=true

# Development Features
ENABLE_HOT_RELOAD=true
ENABLE_SOURCE_MAPS=true
ENABLE_DEBUG_LOGS=false

# =============================================================================
# RESOURCE LIMITS & PERFORMANCE
# =============================================================================

# Agent System Limits
MAX_PARALLEL_AGENTS=8
MAX_LOG_SIZE_MB=100
MAX_TASK_DURATION_MS=300000
AGENT_HEARTBEAT_INTERVAL=30000
AGENT_CLEANUP_INTERVAL=3600000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_SIZE=20

# Memory & Performance
NODE_OPTIONS=--max-old-space-size=4096
UV_THREADPOOL_SIZE=16
MAX_HTTP_HEADER_SIZE=16384

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=development
PORT=3000
HOST=localhost

# Timezone & Locale
TZ=UTC
LANG=en_US.UTF-8

# Build Configuration
BUILD_TARGET=development
BUNDLE_ANALYZER=false
SOURCEMAP=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Object Storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=monorepo-assets
S3_REGION=us-east-1

# Email Service
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourapp.com

# WebSocket Configuration
WS_PORT=3001
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=generate-a-secure-session-secret
SESSION_NAME=monorepo.sid
SESSION_DURATION=86400000
SESSION_SECURE=false

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/api/csp-report

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test Database
TEST_DATABASE_URL=postgresql://orchestrator:orchestrator123@localhost:5432/orchestrator_test

# Test Configuration
TEST_TIMEOUT=30000
TEST_COVERAGE_THRESHOLD=80
TEST_PARALLEL_JOBS=4

# E2E Testing
E2E_BASE_URL=http://localhost:3000
E2E_HEADLESS=true
E2E_VIDEO=false
E2E_SCREENSHOT=true

# =============================================================================
# INFRASTRUCTURE CONFIGURATION
# =============================================================================

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
COMPOSE_PROJECT_NAME=monorepo5

# Kubernetes Configuration (if applicable)
KUBERNETES_NAMESPACE=default
KUBERNETES_CONFIG_PATH=~/.kube/config

# Cloud Provider Configuration (if applicable)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_PROJECT_ID=
GCP_KEY_FILE=

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Development Server
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=3000
DEV_SERVER_HTTPS=false
DEV_SERVER_POLL=false

# Hot Module Replacement
HMR_ENABLED=true
HMR_PORT=3002

# Development Database Seeding
SEED_DATABASE=false
SEED_USERS=true
SEED_SAMPLE_DATA=false

# =============================================================================
# AGENT-SPECIFIC CONFIGURATION
# =============================================================================

# Agent Behavior
AGENT_VERBOSE_LOGGING=false
AGENT_SAFE_MODE=false
AGENT_AUTO_RECOVERY=true
AGENT_ESCALATION_TIMEOUT=1800000

# Guardian Enforcer Settings
GUARDIAN_STRICT_MODE=true
GUARDIAN_AUTO_BLOCK=true
GUARDIAN_AUDIT_ALL=true

# Coordination Settings
COORDINATION_ENABLE_PARALLEL=true
COORDINATION_MAX_DEPTH=5
COORDINATION_TIMEOUT=60000

# Performance Monitoring
PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLING_RATE=0.1
PERFORMANCE_ALERT_THRESHOLD=5000

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=monorepo-backups

# Recovery Configuration
RECOVERY_POINT_OBJECTIVE=1h
RECOVERY_TIME_OBJECTIVE=30m

# =============================================================================
# COMPLIANCE & GOVERNANCE
# =============================================================================

# Compliance Mode (soc2, gdpr, hipaa, pcidss, none)
COMPLIANCE_MODE=soc2

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365
AUDIT_EXPORT_FORMAT=json

# Data Retention
DATA_RETENTION_ENABLED=true
DATA_RETENTION_DAYS=2555  # 7 years

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Add your custom environment variables here
# CUSTOM_FEATURE_FLAG=true
# CUSTOM_API_ENDPOINT=https://api.example.com
# CUSTOM_TIMEOUT=30000