#!/usr/bin/env python3
"""Enhanced audit logger with structured logging"""
import json
import time
import os
import hashlib
from datetime import datetime, timezone
from pathlib import Path

class AuditLogger:
    def __init__(self):
        self.audit_dir = Path(__file__).parent.parent / "audit"
        self.audit_dir.mkdir(exist_ok=True)
        
    def log(self, event_type, agent, action, details=None, severity="info", correlation_id=None):
        """Log an audit event with enhanced metadata"""
        timestamp = datetime.now(timezone.utc)
        event = {
            "timestamp": timestamp.isoformat(),
            "event_type": event_type,
            "agent": agent,
            "action": action,
            "severity": severity,
            "details": details or {},
            "task_id": os.environ.get("TASK_ID", "unknown"),
            "user": os.environ.get("USER", "unknown"),
            "correlation_id": correlation_id or self._generate_correlation_id(),
            "session_id": os.environ.get("SESSION_ID", "unknown"),
            "version": "1.0",
            "environment": os.environ.get("NODE_ENV", "development"),
        }
        
        # Add security context
        if event_type in ["security_violation", "permission_denied", "unauthorized_access"]:
            event["security_context"] = {
                "ip_address": os.environ.get("CLIENT_IP", "unknown"),
                "user_agent": os.environ.get("USER_AGENT", "unknown"),
                "request_id": os.environ.get("REQUEST_ID", "unknown"),
            }
        
        # Write to daily audit file
        audit_file = self.audit_dir / f"audit-{timestamp.strftime('%Y-%m-%d')}.ndjson"
        with open(audit_file, "a", encoding='utf-8') as f:
            f.write(json.dumps(event, ensure_ascii=False) + "\n")
            
        # For critical events, also create alert
        if severity in ["error", "critical"]:
            self._create_alert(event)
            
        # Performance metrics for high-frequency events
        if event_type in ["agent_execution", "api_call", "file_access"]:
            self._record_performance_metric(event)
            
    def _generate_correlation_id(self):
        """Generate a correlation ID for tracing"""
        return hashlib.md5(f"{time.time()}{os.getpid()}".encode()).hexdigest()[:16]
        
    def _create_alert(self, event):
        """Create alert for critical events"""
        alert_file = self.audit_dir / "alerts.ndjson"
        alert = {
            **event,
            "alert_created": datetime.now(timezone.utc).isoformat(),
            "alert_level": "high" if event["severity"] == "critical" else "medium",
        }
        with open(alert_file, "a", encoding='utf-8') as f:
            f.write(json.dumps(alert, ensure_ascii=False) + "\n")
            
    def _record_performance_metric(self, event):
        """Record performance metrics"""
        metrics_file = self.audit_dir / "performance-metrics.ndjson"
        metric = {
            "timestamp": event["timestamp"],
            "event_type": event["event_type"],
            "agent": event["agent"],
            "duration_ms": event["details"].get("duration_ms", 0),
            "success": event["severity"] not in ["error", "critical"],
        }
        with open(metrics_file, "a", encoding='utf-8') as f:
            f.write(json.dumps(metric) + "\n")

# Enhanced helper functions
def log_agent_execution(agent, task, duration_ms=None, success=True, details=None):
    logger = AuditLogger()
    severity = "info" if success else "error"
    event_details = {"task": task, "duration_ms": duration_ms, **(details or {})}
    logger.log("agent_execution", agent, "execute_task", event_details, severity)

def log_file_access(agent, file_path, action="read", details=None):
    logger = AuditLogger()
    event_details = {"file": str(file_path), "action": action, **(details or {})}
    logger.log("file_access", agent, action, event_details)
    
def log_api_call(agent, api, endpoint, status_code, duration_ms=None):
    logger = AuditLogger()
    severity = "error" if status_code >= 400 else "info"
    event_details = {
        "endpoint": endpoint,
        "status_code": status_code,
        "duration_ms": duration_ms,
    }
    logger.log("api_call", agent, f"call_{api}", event_details, severity)
    
def log_security_violation(agent, violation_type, details=None):
    logger = AuditLogger()
    logger.log("security_violation", agent, violation_type, details or {}, "critical")
    
def log_coordination_event(initiator_agent, target_agent, event_type, details=None):
    logger = AuditLogger()
    event_details = {
        "initiator": initiator_agent,
        "target": target_agent,
        **(details or {})
    }
    logger.log("agent_coordination", initiator_agent, event_type, event_details)
EOF

