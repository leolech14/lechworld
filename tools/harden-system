#!/usr/bin/env python3
"""Enhanced input sanitization utilities"""
import re
import os
import json
import yaml
from pathlib import Path
from urllib.parse import urlparse

class InputSanitizer:
    def __init__(self):
        self.max_length = int(os.environ.get("MAX_INPUT_LENGTH", "200000"))
        self.forbidden_patterns = [
            r'\.\./\.\./\.\.',  # Path traversal
            r'/etc/passwd',      # System files
            r'<script[^>]*>',    # XSS attempts
            r'`[^`]*`',          # Command injection
            r'\$\([^)]*\)',      # Command substitution
            r'&&\s*(rm|del|format)',  # Dangerous commands
            r';\s*(rm|del|format)',   # Command chaining
            r'eval\s*\(',        # Code evaluation
            r'exec\s*\(',        # Code execution
            r'__import__\s*\(',  # Python imports
            r'subprocess\.',     # Subprocess calls
            r'os\.system',       # OS commands
        ]
        
        self.dangerous_extensions = {
            '.exe', '.bat', '.cmd', '.com', '.scr', '.pif', 
            '.sh', '.bash', '.zsh', '.fish', '.ps1', '.vbs'
        }
        
    def sanitize_path(self, path_str):
        """Enhanced path sanitization"""
        try:
            # Normalize and resolve path
            path = Path(path_str).resolve()
            
            # Check if path is within project
            project_root = Path(__file__).parent.parent.parent
            try:
                path.relative_to(project_root)
            except ValueError:
                raise ValueError(f"Path outside project: {path}")
                
            # Check forbidden paths
            forbidden = ["/etc", "/sys", "/proc", "/.ssh", "/.aws", "/root", "/var/run/secrets"]
            for f in forbidden:
                if str(path).startswith(f):
                    raise ValueError(f"Forbidden path: {path}")
                    
            # Check dangerous file extensions
            if path.suffix.lower() in self.dangerous_extensions:
                raise ValueError(f"Dangerous file type: {path.suffix}")
                    
            return str(path)
        except Exception as e:
            raise ValueError(f"Invalid path: {e}")
            
    def sanitize_input(self, input_str):
        """Enhanced input sanitization"""
        if not isinstance(input_str, str):
            raise ValueError("Input must be a string")
            
        # Check length
        if len(input_str) > self.max_length:
            raise ValueError(f"Input too long: {len(input_str)} > {self.max_length}")
            
        # Check forbidden patterns
        for pattern in self.forbidden_patterns:
            if re.search(pattern, input_str, re.IGNORECASE | re.MULTILINE):
                raise ValueError(f"Forbidden pattern detected: {pattern}")
                
        # Enhanced escaping
        sanitized = input_str
        
        # SQL injection prevention
        sanitized = sanitized.replace("'", "''")
        sanitized = sanitized.replace(";", "\\;")
        
        # JSON/XSS prevention
        sanitized = sanitized.replace('"', '\\"')
        sanitized = sanitized.replace('<', '&lt;')
        sanitized = sanitized.replace('>', '&gt;')
        
        # Shell injection prevention
        sanitized = sanitized.replace('`', '\\`')
        sanitized = sanitized.replace('$', '\\$')
        
        return sanitized
        
    def sanitize_url(self, url_str):
        """Sanitize URLs"""
        try:
            parsed = urlparse(url_str)
            
            # Check allowed schemes
            allowed_schemes = {'http', 'https', 'ftp', 'sftp'}
            if parsed.scheme.lower() not in allowed_schemes:
                raise ValueError(f"Forbidden URL scheme: {parsed.scheme}")
                
            # Check for localhost/internal addresses in production
            if os.environ.get('NODE_ENV') == 'production':
                forbidden_hosts = {'localhost', '127.0.0.1', '0.0.0.0', '::1'}
                if parsed.hostname in forbidden_hosts:
                    raise ValueError(f"Internal URL not allowed in production: {parsed.hostname}")
                    
            # Check for private IP ranges
            if parsed.hostname:
                import ipaddress
                try:
                    ip = ipaddress.ip_address(parsed.hostname)
                    if ip.is_private and os.environ.get('NODE_ENV') == 'production':
                        raise ValueError(f"Private IP not allowed in production: {ip}")
                except ValueError:
                    pass  # Not an IP address, that's fine
                    
            return url_str
        except Exception as e:
            raise ValueError(f"Invalid URL: {e}")
        
    def validate_json(self, json_str):
        """Enhanced JSON validation"""
        try:
            data = json.loads(json_str)
            
            # Check for dangerous keys
            dangerous_keys = {'__proto__', 'constructor', 'prototype', 'eval', 'function'}
            
            def check_dangerous_keys(obj):
                if isinstance(obj, dict):
                    for key in obj.keys():
                        if key in dangerous_keys:
                            raise ValueError(f"Dangerous JSON key: {key}")
                        check_dangerous_keys(obj[key])
                elif isinstance(obj, list):
                    for item in obj:
                        check_dangerous_keys(item)
                        
            check_dangerous_keys(data)
            return True
        except json.JSONDecodeError as e:
            raise ValueError(f"Invalid JSON: {e}")
        except Exception as e:
            raise ValueError(f"Dangerous JSON content: {e}")
            
    def validate_yaml(self, yaml_str):
        """Validate YAML safely"""
        try:
            # Use safe_load to prevent code execution
            data = yaml.safe_load(yaml_str)
            return True
        except yaml.YAMLError as e:
            raise ValueError(f"Invalid YAML: {e}")
            
    def sanitize_sql(self, sql_str):
        """Basic SQL sanitization (use parameterized queries instead)"""
        # Remove dangerous SQL keywords
        dangerous_keywords = [
            r'\bDROP\b', r'\bDELETE\b', r'\bTRUNCATE\b', r'\bALTER\b',
            r'\bCREATE\b', r'\bINSERT\b', r'\bUPDATE\b', r'\bREPLACE\b',
            r'\bEXEC\b', r'\bEVAL\b', r'\bSP_\w+\b'
        ]
        
        for keyword in dangerous_keywords:
            if re.search(keyword, sql_str, re.IGNORECASE):
                raise ValueError(f"Dangerous SQL keyword detected: {keyword}")
                
        return sql_str
            
