#!/usr/bin/env python3
"""Enhanced Guardian Enforcer validation script"""
import sys
import json
import os
import subprocess
import re
from pathlib import Path
from datetime import datetime

class GuardianValidator:
    def __init__(self):
        self.project_root = Path(__file__).parent.parent.parent.parent
        self.violations = []
        
    def check_file_permissions(self):
        """Check sensitive file permissions"""
        sensitive_patterns = [
            "**/.env*",
            "**/secrets/*",
            "**/*.key",
            "**/*.pem",
            "**/id_rsa*",
            "**/*.p12",
            "**/*.pfx",
        ]
        
        for pattern in sensitive_patterns:
            for file in self.project_root.glob(pattern):
                if file.is_file():
                    stat = file.stat()
                    mode = oct(stat.st_mode)[-3:]
                    if mode != "600":
                        self.violations.append(f"Insecure permissions on {file}: {mode}")
                        
    def check_hardcoded_secrets(self):
        """Scan for potential hardcoded secrets"""
        patterns = [
            r'(api[_-]?key|apikey|secret|password|pwd|token|auth)["\']?\s*[:=]\s*["\'][^"\']{8,}["\']',
            r'(AWS|aws)[_-]?(ACCESS|access)[_-]?(KEY|key)[_-]?(ID|id)?["\']?\s*[:=]\s*["\'][A-Z0-9]{20}["\']',
            r'(AWS|aws)[_-]?(SECRET|secret)[_-]?(ACCESS|access)[_-]?(KEY|key)["\']?\s*[:=]\s*["\'][A-Za-z0-9/+=]{40}["\']',
            r'sk-[a-zA-Z0-9]{48}',  # OpenAI API keys
            r'pk-[a-zA-Z0-9]{48}',  # Anthropic API keys
            r'ghp_[a-zA-Z0-9]{36}', # GitHub tokens
        ]
        
        exclude_patterns = [
            r'\.example$',
            r'\.template$',
            r'\.sample$',
            r'test.*\.(js|ts|py)$',
            r'spec.*\.(js|ts|py)$',
        ]
        
        code_files = list(self.project_root.glob("**/*.py")) + \
                    list(self.project_root.glob("**/*.js")) + \
                    list(self.project_root.glob("**/*.ts")) + \
                    list(self.project_root.glob("**/*.jsx")) + \
                    list(self.project_root.glob("**/*.tsx")) + \
                    list(self.project_root.glob("**/*.yml")) + \
                    list(self.project_root.glob("**/*.yaml")) + \
                    list(self.project_root.glob("**/*.json"))
                    
        for file in code_files:
            if ".git" in str(file) or "node_modules" in str(file):
                continue
                
            # Skip example/template files
            if any(re.search(pattern, str(file), re.IGNORECASE) for pattern in exclude_patterns):
                continue
                
            try:
                content = file.read_text()
                for pattern in patterns:
                    if re.search(pattern, content, re.IGNORECASE | re.MULTILINE):
                        self.violations.append(f"Potential hardcoded secret in {file}")
                        break
            except:
                pass
                
    def check_docker_security(self):
        """Check Docker configurations for security issues"""
        docker_files = list(self.project_root.glob("**/Dockerfile*")) + \
                      list(self.project_root.glob("**/docker-compose*.yml"))
                      
        for file in docker_files:
            try:
                content = file.read_text()
                # Check for running as root
                if re.search(r'USER\s+root', content):
                    self.violations.append(f"Docker file runs as root: {file}")
                    
                # Check for exposed secrets
                if re.search(r'ENV\s+.*(?:PASSWORD|SECRET|TOKEN|KEY)', content, re.IGNORECASE):
                    self.violations.append(f"Environment secrets exposed in Docker: {file}")
            except:
                pass
                
    def check_kubernetes_security(self):
        """Check Kubernetes manifests for security issues"""
        k8s_files = list(self.project_root.glob("**/k8s/**/*.yml")) + \
                   list(self.project_root.glob("**/k8s/**/*.yaml")) + \
                   list(self.project_root.glob("**/kubernetes/**/*.yml")) + \
                   list(self.project_root.glob("**/kubernetes/**/*.yaml"))
                   
        for file in k8s_files:
            try:
                content = file.read_text()
                # Check for privileged containers
                if 'privileged: true' in content:
                    self.violations.append(f"Privileged container in K8s manifest: {file}")
                    
                # Check for root security context
                if re.search(r'runAsUser:\s*0', content):
                    self.violations.append(f"Container runs as root in K8s manifest: {file}")
            except:
                pass
                
    def check_agent_permissions(self):
        """Verify agent tool permissions match configuration"""
        settings_file = self.project_root / ".claude/config/settings_v2.json"
        if settings_file.exists():
            try:
                with open(settings_file) as f:
                    settings = json.load(f)
                    
                allowed_tools = settings.get("security", {}).get("allowed_tools", {})
                
                # Check each agent's declared tools
                agents_dir = self.project_root / ".claude/agents"
                for agent_file in agents_dir.glob("*.md"):
                    content = agent_file.read_text()
                    if "Tools:" in content:
                        # Extract tools list (simplified parsing)
                        tools_section = content.split("Tools:")[1].split("\n")[0]
                        declared_tools = [t.strip() for t in tools_section.split(",")]
                        
                        # Verify against allowed tools
                        agent_name = agent_file.stem
                        for tool in declared_tools:
                            if tool and tool not in ["Read", "Write", "Task"]:
                                # Enhanced validation for dangerous tools
                                dangerous_tools = ["Bash", "Execute", "Shell", "System"]
                                if tool in dangerous_tools:
                                    self.violations.append(f"Agent {agent_name} has dangerous tool: {tool}")
            except:
                pass
                
    def validate(self, pre_commit=False):
        """Run all validation checks"""
        print("🛡️  Guardian Enforcer Validation (Enhanced)")
        print("==========================================")
        
        self.check_file_permissions()
        self.check_hardcoded_secrets()
        self.check_docker_security()
        self.check_kubernetes_security()
        self.check_agent_permissions()
        
        if self.violations:
            print(f"\n❌ Found {len(self.violations)} violations:")
            for v in self.violations:
                print(f"  - {v}")
                
            if pre_commit:
                print("\n⚠️  Commit will proceed, but please address these issues.")
                return 0  # Warning only for now
            return 1
        else:
            print("\n✅ All security checks passed!")
            return 0
            
if __name__ == "__main__":
    validator = GuardianValidator()
    pre_commit = "--pre-commit" in sys.argv
    sys.exit(validator.validate(pre_commit))
EOF

