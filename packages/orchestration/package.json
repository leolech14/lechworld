{
  "name": "@monorepo/orchestration",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "dev": "ts-node-dev src/index.ts"
  },
  "dependencies": {
    "redis": "^4.6.0",
    "amqplib": "^0.10.0",
    "@opentelemetry/api": "^1.7.0",
    "opossum": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/amqplib": "^0.10.4",
    "@types/opossum": "^8.1.9",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.5",
    "ts-jest": "^29.1.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}