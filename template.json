    "dev": "npm run dev",
    "build": "npm run build",
    "test": "npm run test",
    "agent": "./tools/agent-orchestrate"
  },
  "ai_agents": {
    "orchestrator-prime": "Main coordination agent",
    "guardian-enforcer": "Security and compliance",
    "development-lead": "Development coordination",
    "operations-lead": "Infrastructure and deployment",
    "quality-lead": "Testing and quality assurance",
    "ui-specialist": "Frontend development",
    "backend-specialist": "Backend development",
    "database-specialist": "Database design and optimization",
    "bug-detective": "Debugging and troubleshooting",
    "rapid-prototype": "Quick MVP creation"
  },
