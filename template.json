{
  "name": "AI-Ready Monorepo Boilerplate",
  "version": "5.0.0",
  "description": "Production-ready monorepo template with AI agent orchestration, TypeScript, React, and automated tooling",
  "type": "monorepo",
  "author": "Dream Team v2",
  "license": "MIT",
  "features": [
    "AI Agent Orchestration System",
    "TypeScript + React + Vite",
    "Automated Security Hardening",
    "Enhanced Monitoring (505 lines)",
    "Sharded Logging Architecture",
    "Working Applications (Web, API, CLI)",
    "7 Production-Ready Tools",
    "Streamlined Agent Coordination"
  ],
  "replacements": {
    "@your-org": "organization-name",
    "monorepo": "project-name",
    "@YOUR_TEAM": "team-name",
    "Your Name": "author-name"
  },
  "directories": {
    "apps": "Applications (web, api, cli)",
    "packages": "Shared packages and utilities",
    "tools": "CLI tools and scripts",
    ".claude": "AI agent configurations",
    "infrastructure": "Docker, K8s, monitoring configs",
    "docs": "Documentation and guides"
  },
  "requirements": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "git": ">=2.0.0"
